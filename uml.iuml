@startuml chess
skinparam classAttributeIconSize 0
skinparam shadowing false
left to right direction

package "Types" {
  enum Color {
    White
    Black
    NoColor
  }

  class Helpers <<utility>> {
  + oppositeColor: Color
  + colorToString(Color): string
  + playerColorToString(Color): string
  + charToPieceType(char): PieceType
  }

  enum PieceType {
    King
    Queen
    Bishop
    Rook
    Knight
    Pawn
    Empty
  }

  enum MoveType {
    Normal
    Capture
    Castling
    EnPassant
    Promotion
    PawnTwoStep
  }


  enum GameResult {
    Ongoing
    WhiteWins
    BlackWins
    Draw
  }

  enum CheckState {
    None
    WhiteInCheck
    BlackInCheck
    Checkmate
    Stalemate
  }

  class Position {
    - row: int
    - col: int
    + Position(row: int = -1, col: int = -1)
    + getRow(): int
    + getCol(): int
    + isValid(): bool
    + operator==(other: Position): bool
    + operator!=(other: Position): bool
    + fromChess(s: string): Position
    + toChess(): string
  }

  class Move {
    + from: Position
    + to: Position
    + type: MoveType
    + promotionType: PieceType
    + Move(from: Position = Position{}, to: Position = Position{}, type: MoveType = Normal, promotionType: PieceType = Queen)
  }
}

package "The Board" {
  class MoveRecord {
    + move: Move
    + captured: unique_ptr<Piece>
    + movedBefore: bool
    + rookFrom: Position
    + rookTo: Position
    + rookMovedBefore: bool
    + capturedPos: Position
    + previousLastMove: Move
    + previousHasLastMove: bool
  }

  abstract class Piece {
    - color: Color
    - moved: bool
    + Piece(color: Color, moved: bool = false)
    + getColor(): Color
    + hasMoved(): bool
    + setMoved(value: bool): void
    + getType(): PieceType
    + getSymbol(): char
    + canMove(from: Position, to: Position): bool
    + canCapture(from: Position, to: Position): bool
    + clone(): unique_ptr<Piece>
  }

  class King
  class Queen
  class Bishop
  class Rook
  class Knight
  class Pawn {
    + canCapture(from: Position, to: Position): bool
  }

  abstract class Observer {
    + notify(): void
  }

  class Subject {
    - observers: vector<Observer*>
    + attach(ob: Observer*): void
    + detach(ob: Observer*): void
    + notifyObservers(): void
  }

  class Board {
    - theBoard: vector<vector<unique_ptr<Piece>>>
    - turn: Color
    - history: vector<MoveRecord>
    - lastMove: Move
    - hasLastMove: bool
    - inBounds(p: Position): bool
    - pathClear(from: Position, to: Position): bool
    - findKing(color: Color): Position
    - pawnAttack(from: Position, to: Position, by: Color): bool
    - canCastle(from: Position, to: Position): bool
    - canEnPassant(from: Position, to: Position): bool
    - classifyMove(from: Position, to: Position, promotionType: PieceType): Move
    + Board()
    + Board(other: Board)
    + getTurn(): Color
    + setTurn(next: Color): void
    + getPiece(p: Position): Piece*
    + isEmpty(p: Position): bool
    + clear(): void
    + placePiece(type: PieceType, color: Color, p: Position, moved: bool = false): void
    + removePiece(p: Position): void
    + reset(): void
    + squareAttacked(p: Position, by: Color): bool
    + inCheck(color: Color): bool
    + validSetup(): bool
    + pseudoLegal(from: Position, to: Position, promotionType: PieceType = Queen): bool
    + applyMove(move: Move): void
    + undoMove(): void
    + legalMove(from: Position, to: Position, promotionType: PieceType = Queen): bool
    + allLegalMoves(color: Color): vector<Move>
    + hasLegalMove(color: Color): bool
    + getCheckState(): CheckState
    + makeMove(from: Position, to: Position, promotionType: PieceType = Queen): bool
    + drawSquare(p: Position): char
  }
}

package "Displays" {
  class Xwindow {
    - d: Display*
    - w: Window
    - s: int
    - gc: GC
    - colours: unsigned long[10]
    + Xwindow(width: int = 500, height: int = 500)
    + fillRectangle(x: int, y: int, width: int, height: int, colour: int = Black): void
    + drawString(x: int, y: int, msg: string): void
  }

  class TextDisplay {
    - board: Board*
    + TextDisplay(board: Board*)
    + notify(): void
  }

  class GraphicsDisplay {
    - {static} cell: int = 50
    - {static} originX: int = 50
    - {static} originY: int = 50
    - board: Board*
    - win: Xwindow*
    + GraphicsDisplay(board: Board*, win: Xwindow*)
    + notify(): void
  }
}

package "Players and Strategies" {
  abstract class Player {
    - color: Color
    + Player(color: Color)
    + getColor(): Color
    + isHuman(): bool
    + getMove(board: Board): Move
  }

  class HumanPlayer {
    - nextMove: Move
    + HumanPlayer(color: Color)
    + isHuman(): bool
    + setMove(move: Move): void
    + getMove(board: Board): Move
  }

  abstract class Strategy {
    + generateMove(board: Board, color: Color): Move
  }

  class Level1Strategy {
    + generateMove(board: Board, color: Color): Move
  }

  class Level2Strategy {
    + generateMove(board: Board, color: Color): Move
  }

  class Level3Strategy {
    + generateMove(board: Board, color: Color): Move
  }

  class Level4Strategy {
    - pieceValue(type: PieceType): int
    - evaluate(board: Board, color: Color): int
    + generateMove(board: Board, color: Color): Move
  }

  class ComputerPlayer {
    - strategy: unique_ptr<Strategy>
    + ComputerPlayer(color: Color, level: int)
    + isHuman(): bool
    + getMove(board: Board): Move
  }
}

package "Game Flow" {
  class ChessGame {
    - board: Board
    - xwin: unique_ptr<Xwindow>
    - textDisplay: unique_ptr<TextDisplay>
    - graphicsDisplay: unique_ptr<GraphicsDisplay>
    - whitePlayer: unique_ptr<Player>
    - blackPlayer: unique_ptr<Player>
    - whiteScore: double
    - blackScore: double
    - active: bool
    - currentPlayer(): Player*
    - parseLevel(name: string): int
    - resetDisplays(): void
    - setPlayers(white: string, black: string): void
    + ChessGame()
    + getBoard(): Board
    + inGame(): bool
    + startGame(white: string, black: string): void
    + startSetupGame(): void
    + currentIsHuman(): bool
    + playHumanMove(from: Position, to: Position, promo: PieceType = Queen): bool
    + playComputerMove(): bool
    + resign(): void
    + updateResult(): void
    + printFinalScore(): void
  }

  class CommandInterpreter {
    - game: ChessGame
    - parseColor(s: string): Color
    - parsePromotion(s: string): PieceType
    + run(): void
  }
}
' Board
King --|> Piece
Queen --|> Piece
Bishop --|> Piece
Rook --|> Piece
Knight --|> Piece
Pawn --|> Piece
Board --|> Subject
Board *-- "8x8" Piece
Board *-- MoveRecord
Board --> Move
Board --> Position
Board --> CheckState
Piece --> Color
Piece --> PieceType
Piece --> Position

' Types
MoveRecord *-- Piece
Move --> Position
Move --> MoveType
Move --> PieceType
MoveRecord --> Move
MoveRecord --> Position
Subject o-- Observer

' Players and Strategies
HumanPlayer --|> Player
ComputerPlayer --|> Player
Level1Strategy --|> Strategy
Level2Strategy --|> Strategy
Level3Strategy --|> Strategy
Level4Strategy --|> Strategy
Player --> Color
Player --> Board
Player --> Move
HumanPlayer --> Move : nextMove
ComputerPlayer *-- Strategy
Strategy --> Board
Strategy --> Move
Strategy --> Color
Level4Strategy --> PieceType

'Displays

TextDisplay --> Board
GraphicsDisplay --> Board
GraphicsDisplay --> Xwindow
TextDisplay --|> Observer
GraphicsDisplay --|> Observer

' Game Flow
ChessGame *-- Board
ChessGame *-- Xwindow
ChessGame *-- TextDisplay
ChessGame *-- GraphicsDisplay
ChessGame *-- Player : whitePlayer
ChessGame *-- Player : blackPlayer
ChessGame --> Position
ChessGame --> PieceType

CommandInterpreter *-- ChessGame
CommandInterpreter --> Color
CommandInterpreter --> PieceType
CommandInterpreter --> Position

@enduml
